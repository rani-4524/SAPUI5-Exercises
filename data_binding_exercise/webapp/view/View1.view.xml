    <IconTabBar id="_IDGenIconTabBar"
    items="{proddetails>/products}"
    select="onSelect">
    <items>
        <IconTabFilter id="_IDGenIconTabFilter"
            key="{proddetails>ProdDetails/ProdId}"
            icon="{proddetails>icon}"
            text="{proddetails>ProdDetails/ProdName}" />
    </items>
</IconTabBar>
<VBox id="_IDGenVBox1" class="sapUiSmallMargin">

    <HBox id="_IDGenHBox">
        <Label id="_IDGenLabel" text="Price :" width="100px"/>
        <Text id="_IDGenText" text="{proddetails>/selected/otherDetails/Price}"/>
    </HBox>

    <HBox id="_IDGenHBox1">
        <Label id="_IDGenLabel1" text="Currency :" width="100px"/>
        <Text id="_IDGenText1" text="{proddetails>/selected/otherDetails/Currency}"/>
    </HBox>

    <HBox id="_IDGenHBox2">
        <Label id="_IDGenLabel2" text="Status :" width="100px"/>
        <Text id="_IDGenText2" text="{proddetails>/selected/otherDetails/Status}"/>
    </HBox>

    <HBox id="_IDGenHBox3">
        <Label id="_IDGenLabel3" text="Dimension :" width="100px"/>
        <Text id="_IDGenText3" text="{proddetails>/selected/otherDetails/Dimensions}"/>
    </HBox>

</VBox>
    </Page>
