<mvc:View
    controllerName="crudexercise.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Page
        id="_IDGenPage"
        title="Employees"
    >
        <content>
            <VBox
                id="_IDGenVBox1"
                class="sapUiSmallMargin"
            >
                <f:Form
                    id="FormChange354"
                    editable="true"
                >
                    <f:layout>
                        <f:ResponsiveGridLayout
                            id="_IDGenResponsiveGridLayout"
                            labelSpanXL="3"
                            labelSpanL="3"
                            labelSpanM="3"
                            labelSpanS="12"
                            adjustLabelSpan="false"
                            emptySpanXL="4"
                            emptySpanL="4"
                            emptySpanM="4"
                            emptySpanS="0"
                            columnsXL="1"
                            columnsL="1"
                            columnsM="1"
                            singleContainerFullSize="false"
                        />
                    </f:layout>

                    <f:formContainers>
                        <f:FormContainer id="_IDGenFormContainer">
                            <f:formElements>
                                <f:FormElement
                                    id="_IDGenFormElement"
                                    label="Employee ID"
                                >
                                    <f:fields>
                                        <Input id="id1" />
                                    </f:fields>
                                </f:FormElement>

                                <f:FormElement
                                    id="_IDGenFormElement1"
                                    label="First Name"
                                >
                                    <f:fields>
                                        <Input id="id2" />
                                    </f:fields>
                                </f:FormElement>

                                <f:FormElement
                                    id="_IDGenFormElement2"
                                    label="Last Name"
                                >
                                    <f:fields>
                                        <Input id="id3" />
                                    </f:fields>
                                </f:FormElement>

                                <f:FormElement
                                    id="_IDGenFormElement3"
                                    label="Title"
                                >
                                    <f:fields>
                                        <Input id="id4" />
                                    </f:fields>
                                </f:FormElement>
                            </f:formElements>
                        </f:FormContainer>
                    </f:formContainers>
                </f:Form>
            </VBox>

            <Table
                id="idEmployeesTable"
                inset="false"
                items="{/Employees}"
            >
                <columns>
                    <Column
                        id="_IDGenColumn"
                        width="10em"
                    >
                        <Text
                            id="_IDGenText1"
                            text="Employee ID"
                        />
                    </Column>

                    <Column id="_IDGenColumn1">
                        <Text
                            id="_IDGenText2"
                            text="First Name"
                        />
                    </Column>

                    <Column id="_IDGenColumn2">
                        <Text
                            id="_IDGenText3"
                            text="Last Name"
                        />
                    </Column>

                    <Column id="_IDGenColumn3">
                        <Text
                            id="_IDGenText4"
                            text="Title"
                        />
                    </Column>

                    <Column id="_IDGenColumn4">
                        <Text
                            id="_IDGenText5"
                            text="City"
                        />
                    </Column>

                    <Column id="_IDGenColumn5">
                        <Text
                            id="_IDGenText6"
                            text="Country"
                        />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="_IDGenColumnListItem">
                        <cells>
                            <Text
                                id="_IDGenText7"
                                text="{EmployeeID}"
                            />
                            <Text
                                id="_IDGenText8"
                                text="{FirstName}"
                            />
                            <Text
                                id="_IDGenText9"
                                text="{LastName}"
                            />
                            <Text
                                id="_IDGenText10"
                                text="{Title}"
                            />
                            <Text
                                id="_IDGenText11"
                                text="{City}"
                            />
                            <Text
                                id="_IDGenText12"
                                text="{Country}"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <Toolbar id="_IDGenToolbar1">
                <ToolbarSpacer id="_IDGenToolbarSpacer" />

                <Button
                    id="_IDGenButton"
                    text="Read Employee"
                    type="Emphasized"
                    press="readEmployee"
                />
                <Button
                    id="_IDGenButton1"
                    text="Read Single Employee"
                    press="readSingleEmployee"
                />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
