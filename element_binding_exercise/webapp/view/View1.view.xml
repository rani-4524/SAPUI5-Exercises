<mvc:View controllerName="elementbindingexercise.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:I="sap.ui.layout">
    <Page id="page" title="{i18n>title}">
    <List id="_IDGenList1" headerText="{Employee Details}" class="sapUiResponsiveMargin" width="auto" items="{empdetails>/Information}" >
        <items>
        <ObjectListItem id="_IDGenObjectListItem" press=".onItemSelected" type="Active" title="{empdetails>EmpID} {empdetails>EmpName}" />
        </items>
    </List>

    <Panel id="_IDGenPanel" headerText="{i18n>panel4HeaderText}" class="sapUiResponsiveMargin" width="auto">
    <I:Grid id="_IDGenGrid1" defaultSpan="L3 M6 S12" containerQuery="true">

    <Label id="_IDGenLabel" text="Employee ID" />
    <Input id="_IDGenInput" value="{empdetails>EmpID}" />
    <Label id="_IDGenLabel1" text="Employee Name" />
    <Input id="_IDGenInput1" value="{empdetails>EmpName}" />
    <Label id="_IDGenLabel2" text="Employee Skills" />
    <Input id="_IDGenInput2" value="{empdetails>EmpSkills}" />
    <Label id="_IDGenLabel3" text="Gender" />
    <Input id="_IDGenInput3" value="{empdetails>Gender}" />
    </I:Grid>
    </Panel>

    <!-- From this Exercise Start above code is for practice -->

    <VBox id="_IDGenVBox" class="sapUiSmallMargin">
        <Table id="_IDGenTable" items="{empdetails2>/Information}" mode="SingleSelectMaster" itemPress="onPress">
            <columns>
                <Column id="_IDGenColumn">
                <Text id="_IDGenText" text="Employee ID" />
            </Column>
            <Column id="_IDGenColumn1">
                <Text id="_IDGenText1" text="Employee Name" />
            </Column>
            <Column id="_IDGenColumn2">
                <Text id="_IDGenText2" text="Employee Location" />
            </Column>
            </columns>

            <items>
            <ColumnListItem id="_IDGenColumnListItem" type="Active">
            <cells>
            <Text id="_IDGenText3" text="{empdetails2>EmpID}" />
            <Text id="_IDGenText4" text="{empdetails2>EmpName}" />
            <Text id="_IDGenText5" text="{empdetails2>Location}" />
            </cells>
            </ColumnListItem>
            </items>

        </Table>
        <Panel id="_IDGenPanel2" headerText="Employee Details" class="sapUiSmallMarginTop" >
        <VBox id="_IDGenVBox1" class="sapUiSmallMargin" >
        <HBox id="_IDGenHBox" class="sapUiSmallMarginBottom" >
        <Label id="_IDGenLabel4" text="Employee ID" width="150px"/>
        <Input id="_IDGenInput4" value="{empdetails2>EmpID}" editable="false" width="200px"/>
        <Label id="_IDGenLabel5" text="Employee Name" width="150px" class="sapUiSmallMarginBegin"/>
        <Input id="_IDGenInput5" value="{empdetails2>EmpName}" editable="false" width="200px"/>

        </HBox>

        <HBox id="_IDGenHBox1" class="sapUiSmallMarginBottom">
        <Label id="_IDGenLabel7" text="EmpRole" width="150px" />
        <Input id="_IDGenInput6" value="{empdetails2>EmpRole}" editable="false" width="200px"/>
        <Label id="_IDGenLabel8" text="EmpPskill" width="150px" class="sapUiSmallMarginBegin"/>
        <Input id="_IDGenInput7" value="{empdetails2>EmpPskill}" editable="false"/>
        </HBox>

        <HBox id="_IDGenHBox2">
        <Label id="_IDGenLabel9" text="Employee Unit" width="150px" />
        <Input id="_IDGenInput8" value="{empdetails2>EmpUnit}" editable="false" width="200px"/>
        </HBox>
        </VBox>
        </Panel>
    </VBox>
    </Page>
</mvc:View>