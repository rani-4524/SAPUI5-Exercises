<mvc:View controllerName="odataexercise.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="_IDGenPage" title="Northwind Products">
    <content>
        <Table
            id="productTable"
            items="{/Products}"
        >
            <columns>
                <Column id="_IDGenColumn">
                    <Text id="_IDGenText1" text="Product ID" />
                </Column>

                <Column id="_IDGenColumn1">
                    <Text id="_IDGenText2" text="Product Name" />
                </Column>

                <Column id="_IDGenColumn2">
                    <Text id="_IDGenText3" text="Unit Price" />
                </Column>

                <Column id="_IDGenColumn3">
                    <Text id="_IDGenText4" text="Units In Stock" />
                </Column>
            </columns>

            <items>
                <ColumnListItem id="_IDGenColumnListItem">
                    <cells>
                        <Text id="_IDGenText5" text="{ProductID}" />

                        <Text id="_IDGenText6" text="{ProductName}" />

                        <Text id="_IDGenText7" text="{UnitPrice}" />

                        <Text id="_IDGenText8" text="{UnitsInStock}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </content>
</Page>

</mvc:View>