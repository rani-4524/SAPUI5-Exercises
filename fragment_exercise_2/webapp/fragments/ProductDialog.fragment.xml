<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog id="_IDGenDialog"
        title="Product Details"
        contentWidth="700px"
    >
        <content>
            <VBox id="_IDGenVBox" class="sapUiSmallMargin">
                <Image id="_IDGenImage"
                    src="images/accenture_logo.png"
                    width="220px"
                    class="sapUiSmallMarginBottom"
                />

                <Table id="_IDGenTable" items="{products>/Products}">
                    <columns>
                        <Column id="_IDGenColumn">
                            <Text id="_IDGenText" text="Product" />
                        </Column>

                        <Column id="_IDGenColumn1">
                            <Text id="_IDGenText1" text="Supplier" />
                        </Column>

                        <Column id="_IDGenColumn2">
                            <Text id="_IDGenText2" text="Status" />
                        </Column>

                        <Column id="_IDGenColumn3">
                            <Text id="_IDGenText3" text="Quantity" />
                        </Column>

                        <Column id="_IDGenColumn4">
                            <Text id="_IDGenText4" text="Price" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem id="_IDGenColumnListItem">
                            <cells>
                                <Text id="_IDGenText5" text="{products>ProductName}" />
                                <Text id="_IDGenText6" text="{products>ShipperName}" />
                                <Text id="_IDGenText7" text="{products>Status}" />
                                <Text id="_IDGenText8" text="{products>Quantity}" />
                                <Text id="_IDGenText9" text="{products>ExtendedPrice}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>

        <beginButton>
            <Button id="_IDGenButton2"
                text="Close"
                press="onCloseDialog"
            />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>
