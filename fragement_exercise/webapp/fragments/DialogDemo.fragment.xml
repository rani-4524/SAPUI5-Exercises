<core:FragmentDefinition  xmlns:html="http://www.w3.org/1999/xhtml" xmlns:core="sap.ui.core"  xmlns="sap.m">

<Dialog id="_IDGenDialog1" title="Product Details">

<VBox id="_IDGenVBox3">

    <Table id="_IDGenTable1"  items="{ProdData>/Products}">

                        <headerToolbar>

                            <Toolbar id="_IDGenToolbar1">

                                <content>

                                    <Title id="_IDGenTitle1" text="Products"  level="H2"/>

                                    <ToolbarSpacer id="_IDGenToolbarSpacer1"/>

                                </content>

                            </Toolbar>

                        </headerToolbar>

                        <columns>

                            <Column id="_IDGenColumn1" width="12em">

                                <Text id="_IDGenText1" text="Product"/>

                            </Column>

                            <Column id="_IDGenColumn2">

                                <Text id="_IDGenText2" text="Supplier"/>

                            </Column>

                            <Column id="_IDGenColumn3">

                                <Text id="_IDGenText3" text="Status"/>

                            </Column>

                            <Column id="_IDGenColumn4">

                                <Text id="_IDGenText4" text="Weight"/>

                            </Column>

                            <Column id="_IDGenColumn5">

                                <Text id="_IDGenText5" text="Price"/>

                            </Column>

                        </columns>

                        <items>

                            <ColumnListItem id="_IDGenColumnListItem1">

                                <cells>

                                    <Text id="_IDGenText6" text="{ProdData>ProductName}"/>

                                   

                                    <Text id="_IDGenText7" text="{ProdData>ShipperName}"/>

                                    <Text id="_IDGenText8" text="{ProdData>Status}"/>

                                    <Text id="_IDGenText9" text="{ProdData>Quantity}"/>

                                    <Text id="_IDGenText10" text="{ProdData>ExtendedPrice}"/>

                                </cells>

                            </ColumnListItem>

                        </items>

                    </Table>

<Text id="_IDGenText11" text="Welcome,{dialogmodels>/name}"></Text>

<Button id="_IDGenButton4" text="CloseDialog"   press="onCloseDialog"></Button>

 </VBox>

</Dialog>  

</core:FragmentDefinition>


