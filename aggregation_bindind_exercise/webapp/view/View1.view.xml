<mvc:View
    controllerName="aggregationbindindexercise.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <List
            id="_IDGenList1"
            headerText="{Employee Details}"
            class="sapUiResponsiveMargin"
            width="auto"
            items="{empdetails>/Information}"
        >
            <items>
                <ObjectListItem
                    id="_IDGenObjectListItem1"
                    press=".onItemSelected"
                    type="Active"
                    title="{empdetails>EmpID} {empdetails>EmpName}"
                >
                    <ObjectAttribute
                        id="empskill"
                        text="{empdetails>Skill}"
                    />
                </ObjectListItem>
            </items>
        </List>

        <!-- From this Another Exercise -->

        <Table
            id="_IDGenTable1"
            items="{emp>/empdata}"
        >
            <columns>
                <Column id="_IDGenColumn">
                    <Text
                        id="_IDGenText"
                        text="Employee ID"
                    />
                </Column>

                <Column id="_IDGenColumn1">
                    <Text
                        id="_IDGenText1"
                        text="Employee Name"
                    />
                </Column>

                <Column id="_IDGenColumn2">
                    <Text
                        id="_IDGenText2"
                        text="Location"
                    />
                </Column>
            </columns>

            <items>
                <ColumnListItem id="_IDGenColumnListItem">
                    <cells>
                        <Text
                            id="_IDGenText3"
                            text="{emp>empid}"
                        />

                        <Text
                            id="_IDGenText4"
                            text="{emp>empname}"
                        />

                        <Text
                            id="_IDGenText5"
                            text="{emp>emploc}"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Page>
</mvc:View>
